{
	"name": "newsletters-nx",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"preinstall": "./tools/scripts/preinstall.sh",
		"dev": "USE_IN_MEMORY_STORAGE='true' nx run-many --target=serve --all",
		"dev-api": "USE_IN_MEMORY_STORAGE='true' NEWSLETTERS_UI_SERVE='false' nx run newsletters-api:serve ",
		"dev:s3": "USE_IN_MEMORY_STORAGE='false' nx run-many --target=serve --all",
		"lint": "nx run-many --target=lint --all",
		"build": "nx run-many --target=build --all",
		"test": "nx run-many --target=test --all",
		"generate:lib": "npx nx generate @nx/workspace:library --setParserOptionsProject --standaloneConfig --testEnvironment=node --",
		"prepare": "husky",
		"generate-newsletters": "./tools/scripts/generate-newsletters.sh",
		"postinstall": "npm install --prefix cdk",
		"bundle:api": "npx nx build newsletters-api --configuration=production --outputFileName=index.js",
		"bundle:ui": "npx nx build newsletters-ui --configuration=production",
		"upgrade-nx": "nx migrate latest && nx migrate --run-migrations",
		"test:e2e": "nx e2e newsletters-e2e --skip-nx-cache",
		"test:e2e:ui": "nx e2e newsletters-e2e --headed --skip-nx-cache",
		"test:e2e:debug": "nx e2e newsletters-e2e --debug --skip-nx-cache",
		"test:e2e:api": "cd apps/newsletters-e2e && npx playwright test src/api",
		"test:e2e:ui-only": "cd apps/newsletters-e2e && npx playwright test src/ui"
	},
	"engines": {
		"node": ">=16.19.0",
		"npm": ">=8.19.3"
	},
	"private": true,
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1030.0",
		"@aws-sdk/client-ses": "^3.1030.0",
		"@aws-sdk/client-ssm": "^3.1030.0",
		"@aws-sdk/credential-providers": "^3.1030.0",
		"@emotion/css": "^11.13.5",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@guardian/image": "^1.1.0",
		"@guardian/source": "^12.2.1",
		"@guardian/stand": "^0.0.22",
		"@mui/icons-material": "^9.0.0",
		"@mui/material": "^9.0.0",
		"@mui/x-date-pickers": "^9.0.0",
		"@types/react-table": "^7.7.14",
		"body-parser": "^2.2.0",
		"dayjs": "^1.11.20",
		"express": "^5.1.0",
		"express-rate-limit": "^8.3.2",
		"highlight.js": "^11.11.1",
		"instead": "^1.0.3",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.14.0",
		"react-table": "^7.8.0",
		"tslib": "^2.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.14.5",
		"@babel/preset-react": "^7.14.5",
		"@emotion/babel-plugin": "^11.13.5",
		"@faker-js/faker": "^10.4.0",
		"@guardian/eslint-config": "^9.0.0",
		"@guardian/eslint-config-typescript": "^12.0.0",
		"@guardian/prettier": "^10.0.0",
		"@guardian/tsconfig": "^1.0.1",
		"@jest/types": "^30.3.0",
		"@nx/esbuild": "22.6.5",
		"@nx/eslint": "22.6.5",
		"@nx/eslint-plugin": "22.6.5",
		"@nx/jest": "22.6.5",
		"@nx/js": "22.6.5",
		"@nx/node": "22.6.5",
		"@nx/react": "22.6.5",
		"@nx/vite": "22.6.5",
		"@nx/vitest": "22.6.5",
		"@nx/workspace": "22.6.5",
		"@playwright/test": "^1.59.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.19.0",
		"@types/react": "18.3.1",
		"@types/react-dom": "18.3.0",
		"@typescript-eslint/eslint-plugin": "^8.13.0",
		"@typescript-eslint/parser": "^8.13.0",
