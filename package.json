		"path-to-regexp@^8": "8.4.0",
		"flatted@^3": "3.4.2",
		"@typescript-eslint/eslint-plugin": "$@typescript-eslint/eslint-plugin",
		"@typescript-eslint/parser": "$@typescript-eslint/parser"
	}
}
