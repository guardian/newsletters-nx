{
	"name": "state-machine",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "libs/state-machine/src",
	"projectType": "library",
	"tags": [],
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/dist/libs/state-machine"],
			"inputs": ["production", "^production"],
			"cache": true,
			"dependsOn": ["^build"],
			"options": {
				"commands": [
					"npx tsc -p libs/state-machine/tsconfig.lib.json",
					"cp libs/state-machine/*.md dist/libs/state-machine/ 2>/dev/null || true"
				],
				"parallel": false,
				"cwd": "{workspaceRoot}"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"outputs": ["{options.outputFile}"]
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "libs/state-machine/jest.config.ts"
			}
		}
	}
}
