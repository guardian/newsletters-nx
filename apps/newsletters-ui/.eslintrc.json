{
	"extends": ["plugin:@nx/react", "../../.eslintrc.json"],
	"ignorePatterns": [
		"!**/*",
		"**/vite.config.*.timestamp*",
		"**/vitest.config.*.timestamp*"
	],
	"overrides": [
		{
			"files": ["*.ts", "*.tsx"],
			"parserOptions": {
				"project": ["apps/newsletters-ui/tsconfig.*?.json"]
			},
			"rules": {}
		},
		{
			"files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
			"rules": {}
		},
		{
			"files": ["*.js", "*.jsx"],
			"rules": {}
		}
	]
}
