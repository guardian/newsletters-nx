{
	"name": "newsletters-api",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/newsletters-api/src",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/dist/apps/newsletters-api"],
			"options": {
				"command": "node apps/newsletters-api/build.mjs"
			}
		},
		"serve": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npx tsx watch apps/newsletters-api/src/main.ts"
			}
		},
		"lint": {
			"executor": "@nx/linter:eslint",
			"outputs": ["{options.outputFile}"],
			"options": {
				"lintFilePatterns": ["apps/newsletters-api/**/*.ts"]
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "apps/newsletters-api/jest.config.ts",
				"passWithNoTests": true
			}
		}
	},
	"tags": []
}
